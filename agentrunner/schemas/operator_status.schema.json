{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentrunner operator status",
  "type": "object",
  "required": [
    "project",
    "status",
    "current",
    "queue",
    "initiative",
    "lastCompleted",
    "warnings",
    "updatedAt"
  ],
  "properties": {
    "project": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["active", "blocked", "idle-clean", "idle-pending", "conflicted"]},
    "current": {
      "type": ["object", "null"],
      "properties": {
        "queueItemId": {"type": "string"},
        "role": {"type": "string", "enum": ["architect", "developer", "reviewer", "manager", "merger"]},
        "branch": {"type": ["string", "null"]},
        "startedAt": {"type": ["string", "null"], "description": "ISO-8601 timestamp"},
        "ageSeconds": {"type": ["integer", "null"], "minimum": 0}
      },
      "required": ["queueItemId", "role"],
      "additionalProperties": true
    },
    "queue": {
      "type": "object",
      "required": ["depth", "nextIds"],
      "properties": {
        "depth": {"type": "integer", "minimum": 0},
        "nextIds": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "initiative": {
      "type": ["object", "null"],
      "properties": {
        "initiativeId": {"type": ["string", "null"]},
        "phase": {"type": ["string", "null"]},
        "currentSubtaskId": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "lastCompleted": {
      "type": ["object", "null"],
      "properties": {
        "queueItemId": {"type": "string"},
        "role": {"type": "string", "enum": ["architect", "developer", "reviewer", "manager", "merger"]},
        "status": {"type": ["string", "null"]},
        "summary": {"type": ["string", "null"]},
        "endedAt": {"type": ["string", "null"], "description": "ISO-8601 timestamp"}
      },
      "required": ["queueItemId", "role"],
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "summary"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["info", "warning", "error"]},
          "summary": {"type": "string", "minLength": 1},
          "details": {},
          "source": {"type": ["string", "null"]},
          "precedence": {"type": ["integer", "null"]}
        },
        "additionalProperties": true
      }
    },
    "reconciliation": {
      "type": ["object", "null"],
      "properties": {
        "decision": {"type": "string", "enum": ["active", "blocked", "idle-clean", "idle-pending", "conflicted"]},
        "summary": {"type": ["string", "null"]},
        "reasons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "source", "severity", "summary", "precedence"],
            "properties": {
              "code": {"type": "string", "minLength": 1},
              "source": {"type": "string", "minLength": 1},
              "severity": {"type": "string", "enum": ["info", "warning", "error"]},
              "summary": {"type": "string", "minLength": 1},
              "details": {},
              "precedence": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": true
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "present", "precedence", "freshness", "authority"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "present": {"type": "boolean"},
              "precedence": {"type": "integer", "minimum": 1},
              "freshness": {"type": "string", "minLength": 1},
              "authority": {"type": "string", "minLength": 1},
              "details": {}
            },
            "additionalProperties": true
          }
        },
        "policy": {
          "type": ["object", "null"],
          "properties": {
            "name": {"type": "string"},
            "version": {"type": "integer", "minimum": 1},
            "freshness": {"type": ["object", "null"]},
            "precedenceOrder": {"type": ["array", "null"], "items": {"type": "string"}}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "updatedAt": {"type": "string", "description": "ISO-8601 timestamp"}
  },
  "additionalProperties": true,
  "$comment": "operator_status.json is a derivative operator-facing summary artifact under ~/.agentrunner/projects/<project>/operator_status.json. queue.json remains a materialized view, not an enqueue authority."
}
